# Copy this file to .env and adjust values only if you need to override defaults.

# Whisper model to load on startup: tiny, base, small, medium, large-v3
WHISPER_MODEL=small

# Device selection: auto, cpu, cuda
WHISPER_DEVICE=auto

# Leave empty to let the app choose automatically.
WHISPER_COMPUTE_TYPE=

# Optional: limit CPU threads used by Faster-Whisper.
# WHISPER_CPU_THREADS=4

# Optional: custom global shortcut for dictation.
FLOW_HOTKEY=ctrl+windows

# Optional: custom shortcut to paste the last transcription.
FLOW_PASTE_LAST_HOTKEY=

# Detection languages, comma-separated ISO codes.
ALLOWED_LANGUAGES=en

# Interface language. Defaults to English.
INTERFACE_LANGUAGE=en

# Optional advanced overrides.
# PYTHON_BIN=python
# WHISPER_MODEL_DIR=
